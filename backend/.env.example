# =============================================================================
# Kopieer naar .env: cp .env.example .env
# Monorepo (optioneel): ln -sf backend/.env .env  (vanaf repo-root)
# =============================================================================

APP_NAME=NEXA
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8085

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Standaard database (users, modules, general_settings, website_pages, …)
# Optioneel: DB_URL=pgsql://user:pass@127.0.0.1:5432/nexa
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nexa
DB_USERNAME=postgres
DB_PASSWORD=

# N8N: externe workflow-service (optioneel)
N8N_URL=https://n8n.example.com
N8N_PORT=5678
N8N_EMAIL=admin@example.com
N8N_PASSWORD=changeme

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# php artisan key:generate
APP_KEY=

ADMIN_DEBUG_PANEL_ENABLED=true

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ZOOM=12
GOOGLE_MAPS_CENTER_LAT=52.3676
GOOGLE_MAPS_CENTER_LNG=4.9041
GOOGLE_MAPS_TYPE=roadmap
GOOGLE_MAPS_MAP_ID=

# true = alle module-tabellen in de hoofddatabase; geen aparte nexa_* module-DB’s
# false = per module eigen database (nexa_taxi, etc.) op PostgreSQL/MySQL
# Module database strategie: single | schema | database
# single   = alles in de hoofd-DB (public schema)
# schema   = 1 database, per module een eigen PG-schema (aanbevolen)
# database = per module een eigen database (legacy)
MODULE_DATABASE_STRATEGY=schema
