# =============================================================================
# Kopieer naar .env: cp .env.example .env
# Monorepo (optioneel): ln -sf backend/.env .env  (vanaf repo-root)
# =============================================================================

APP_NAME=NEXA
APP_ENV=local
APP_DEBUG=true
# Performance lokaal: Xdebug (xdebug.start_with_request=yes) maakt elke request veel trager.
# Gebruik `composer serve:fast` of zet XDEBUG_MODE=off. Optioneel: `composer optimize:local`.
APP_URL=http://localhost:8085

# Multi-tenant SaaS (ResolveTenantFromHost): Host-header bepaalt het bedrijf.
# — Geen /etc/hosts op de server: gebruik DNS wildcard (*.nexasuite.nl → jouw load balancer).
# — APP_URL-host + TENANCY_CENTRAL_DOMAINS = "centraal" (admin/marketing), géén tenant-resolutie.
# — NOOIT APP_URL op een klant-subdomein zetten (bijv. taxitest.nexasuite.nl): dan wordt dat domein
#   altijd als centraal gezien en zie je géén tenant-website op die host. Houd APP_URL op localhost of je admin-URL.
# — TENANCY_TENANT_PARENT_DOMAINS: subdomeinen {slug}.nexasuite.nl worden aan een actief bedrijf
#   gekoppeld via slug of naam-slug (zonder rij in company_domains). Komma-gescheiden.
# — Alternatief: expliciete rijen in admin → Tenant domeinen (company_domains.host).
# — Lokaal (APP_ENV=local): optioneel host → company_id forceren als slug/DNS nog niet klopt:
#   TENANCY_DEV_HOST_COMPANY_MAP=taxitest.nexasuite.nl:2
# — Lokaal zonder DNS/hosts: tenant als op dat domein simuleren op localhost of LAN-IP:
#   TENANCY_DEV_EFFECTIVE_HOST_QUERY=_tenant_host
#   → Eén keer: http://localhost:8085/?_tenant_host=taxitest.nexasuite.nl (sessie bewaart de host;
#     daarna /contact, /about, /{slug} zonder query). Leeg maken: ?_tenant_host=
#   → Mobiel op hetzelfde netwerk: http://192.168.x.x:8085/?_tenant_host=taxitest.nexasuite.nl
#     (private IP’s tellen in niet-productie ook als centrale dev-entry; anders zie je de standaard Nexa-site).
#   (De URL http://taxitest...:8085 in de browser vereist nog steeds dat die hostnaam naar jouw machine wijst.)
TENANCY_CENTRAL_DOMAINS=
TENANCY_TENANT_PARENT_DOMAINS=
TENANCY_DEV_HOST_COMPANY_MAP=
TENANCY_DEV_EFFECTIVE_HOST_QUERY=

# Optioneel: database-push (doel-URL); SSH-tunnel kan ook in Admin → Instellingen → Omgeving-sync.
# Op productie: zet TENANT_SYNC_ALLOW_PRODUCTION_PUSH=true alleen als push vanaf die server bewust is toegestaan.
TENANT_SYNC_TARGET_DATABASE_URL=
TENANT_SYNC_PUSH_ENABLED=false
TENANT_SYNC_ALLOW_PRODUCTION_PUSH=false

# Uploadlimieten (tenant-ZIP import). Nginx vóór PHP moet ook groot genoeg zijn (deploy/nginx-nexa.conf: client_max_body_size 512M).
# UPLOAD_MAX_FILESIZE=512M
# POST_MAX_SIZE=520M
# TENANT_BUNDLE_MAX_KB=512000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Standaard database (users, modules, general_settings, website_pages, …)
# Docker Compose: zet in repo-root .env DB_HOST=db (service in docker-compose.postgres.yml).
# Optioneel: DB_URL=pgsql://user:pass@db:5432/nexa
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=nexa
DB_USERNAME=nexa
DB_PASSWORD=

# N8N: externe workflow-service (optioneel)
N8N_URL=https://n8n.example.com
N8N_PORT=5678
N8N_EMAIL=admin@example.com
N8N_PASSWORD=changeme

# AI-chat: publieke Laravel-URL voor n8n live-query callbacks (VERPLICHT als n8n extern draait).
# APP_URL=http://localhost:8085 werkt niet vanuit n8n — gebruik je publieke HTTPS-domein:
# AI_CHAT_LARAVEL_API_URL=https://nexasuite.nl
# AI_CHAT_LARAVEL_LIVE_QUERY_PATH=/integrations/n8n/ai-chat/live-query
# AI_CHAT_SQL_TOKEN_TTL=120

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# php artisan key:generate
APP_KEY=

ADMIN_DEBUG_PANEL_ENABLED=true

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ZOOM=12
GOOGLE_MAPS_CENTER_LAT=52.3676
GOOGLE_MAPS_CENTER_LNG=4.9041
GOOGLE_MAPS_TYPE=roadmap
GOOGLE_MAPS_MAP_ID=

# Module-tabellen: één database (DB_DATABASE), per module een PostgreSQL-schema (nexa_taxi, …).
# Alleen wijzigen bij uitzondering: database = aparte DB per module; single = alles in public.
MODULE_DATABASE_STRATEGY=schema

# Nexa Taxi – chauffeur dispatch (headless API + mobiele app)
# Standaard acceptatietijd chauffeur-aanbod (seconden); per tenant ook in admin → Nexa Taxi → Chauffeur dispatch
TAXI_DISPATCH_OFFER_TTL=300
TAXI_DISPATCH_BATCH_SIZE=8
# SSE push: false bij local/Docker (php artisan serve = 1 thread). true op productie met PHP-FPM.
TAXI_DISPATCH_STREAM_ENABLED=false
TAXI_DISPATCH_POLL_MS=2000
TAXI_DRIVER_TOKEN_DAYS=14
# Mollie taxi-betalingen: testproviders ook als "Actief" uit (standaard aan buiten productie)
TAXI_DISPATCH_ALLOW_MOLLIE_TEST=true
# Publieke webhook voor Mollie (ngrok). Leeg = geen webhook bij localhost/LAN (betaling via polling)
# TAXI_MOLLIE_WEBHOOK_URL=https://jouw-subdomein.ngrok-free.app/api/taxi/webhooks/mollie
