# Plaats als apart bestand onder /etc/sudoers.d/ (bijv. nexa-deploy) en chmod 440.
# Pas de eerste kolom aan naar de gebruiker van de GitHub Actions runner
# (vaak "runner" of de user uit ./config.sh).
#
# Hiermee mag die gebruiker het deploy-script uitvoeren als nexas4479 zonder wachtwoord,
# passend bij de workflow: sudo -n -u nexas4479 /usr/local/bin/deploy-taxiroyaal.sh
#
# runner ALL=(nexas4479) NOPASSWD: /usr/local/bin/deploy-taxiroyaal.sh
